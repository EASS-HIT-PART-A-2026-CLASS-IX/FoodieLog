# Copy this file to .env and fill in your values.
# Never commit .env to git.

FOODIE_DATABASE_URL=sqlite:///./data/foodie.db
FOODIE_REDIS_URL=redis://localhost:6379/0
FOODIE_RATE_LIMIT_PER_MINUTE=20

# JWT — generate a strong secret before deploying:
#   python -c "import secrets; print(secrets.token_hex(32))"
FOODIE_JWT_SECRET=change-me-in-production
FOODIE_JWT_ISSUER=foodielog
FOODIE_JWT_AUDIENCE=foodielog-clients
FOODIE_JWT_EXPIRY_MINUTES=30

# Async refresh worker
FOODIE_API_BASE_URL=http://localhost:8000
FOODIE_REFRESH_MAX_CONCURRENCY=4
FOODIE_TRACE_ID=foodielog-refresh
# The refresh worker logs in with these credentials to obtain a JWT
# (defaults to the seeded demo admin account).
FOODIE_REFRESH_USER_EMAIL=admin@foodielog.com
FOODIE_REFRESH_USER_PASSWORD=admin123

# AI assistant (Groq — OpenAI-compatible API)
# Get a free key at https://console.groq.com (no credit card needed).
FOODIE_GROQ_API_KEY=gsk_your_key_here
FOODIE_GROQ_MODEL=llama-3.3-70b-versatile
